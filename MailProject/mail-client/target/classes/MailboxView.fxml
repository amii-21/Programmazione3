<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mail.client.controller.MailboxController">

    <left>
        <VBox spacing="10">
            <padding><Insets top="10" left="10"/></padding>
            <Label text="Inbox" />
            <ListView fx:id="emailListView" prefWidth="250" prefHeight="400"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="10">
            <padding><Insets top="10" left="10" right="10"/></padding>
            <Label text="Email Details" />

            <TextField fx:id="subjectField" editable="false"/>
            <TextArea fx:id="bodyArea" editable="false" prefRowCount="15"/>

            <HBox spacing="10">
                <Button text="Reply" onAction="#replyToEmail"/>
                <Button text="Reply All" onAction="#replyAll"/>
                <Button text="Forward" onAction="#forwardEmail"/>
                <Button text="Delete" onAction="#deleteEmail"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <VBox spacing="10">
            <padding><Insets bottom="10" left="10" right="10"/></padding>
            <Label text="Compose new email" />

            <TextField fx:id="composeRecipients" promptText="Recipients (comma separated)" />
            <TextField fx:id="composeSubject" promptText="Subject" />
            <TextArea fx:id="composeBody" promptText="Write your message here..." />

            <HBox spacing="10">
                <Button text="New Message" onAction="#clearCompose"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Send" onAction="#sendEmail"/>
            </HBox>

           <Label fx:id="connectionStatus"
                  text="Server: UNKNOWN"
                  style="-fx-text-fill: grey;" />
       </VBox>
   </bottom>

</BorderPane>
